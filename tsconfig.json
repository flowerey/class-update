{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "rootDir": "./src",
    "outDir": "./prod",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "removeComments": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "baseUrl": "./src"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "prod", "**/* copy*"]
}
